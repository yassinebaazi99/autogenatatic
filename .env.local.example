# Copy to .env.local and fill in. .env.local is gitignored.
# Prisma's DATABASE_URL lives in .env (not .env.local) so the CLI picks it up.

# Anthropic (Claude) — used for image analysis and the agent swarm
ANTHROPIC_API_KEY=""

# Google (Gemini / Nano Banana) — used for image generation
GOOGLE_API_KEY=""

# Optional: where generated landing pages are written.
# Default is ./generated relative to the landing-forge root.
# GENERATED_DIR="./generated"
