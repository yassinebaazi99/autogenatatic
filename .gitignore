# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# landing-forge
/prisma/dev.db
/prisma/dev.db-journal
# Note: dev.db (project root), public/uploads, and public/generated are
# intentionally committed so brand data and generated statics sync across
# machines. Remove them from the repo if you prefer a code-only checkout.
/generated
/.fixtures

# typescript
*.tsbuildinfo
next-env.d.ts
